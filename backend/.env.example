# OpenAI
OPENAI_API_KEY=<your_openai_api_key>
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEMPERATURE=0

# Порог маршрутизации в deep analysis
ANOMALY_THRESHOLD=0.6
SGR_MAX_ITERATIONS=8
WINDOW_HISTORY_LIMIT=5

# Абсолютные пути к данным
TELEMETRY_CSV_PATH=/Users/litvan/space_agent/data_opssat/uhf_telemetry.csv
TLE_PATH=/Users/litvan/space_agent/data_opssat/tle_opssat.txt

# Параметры предобработки
RESAMPLE_FREQ=30s
WINDOW_MINUTES=10
STEP_MINUTES=10

# Наземная станция
GROUND_STATION_LAT=55.7558
GROUND_STATION_LON=37.6173
GROUND_STATION_VISIBILITY_KM=2500

# Логи
LOGS_DIR=/Users/litvan/space_agent/logs
LOG_FILE_PATH=/Users/litvan/space_agent/logs/space_agent.log

# Абсолютные пути к промптам
CLASSIFICATION_PROMPT_PATH=/Users/litvan/space_agent/backend/src/space_log_agent/prompts/classification_system.txt
DEEP_SYSTEM_PROMPT_PATH=/Users/litvan/space_agent/backend/src/space_log_agent/prompts/deep_system.txt
DEEP_USER_PROMPT_PATH=/Users/litvan/space_agent/backend/src/space_log_agent/prompts/deep_user.txt
